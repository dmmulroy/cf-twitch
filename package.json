{
	"name": "cf-twitch",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vp run --filter \"./apps/*\" build",
		"dev": "vp run --filter cf-twitch-api dev",
		"deploy": "vp run --filter \"./apps/*\" deploy",
		"typecheck": "vp run --filter \"./apps/*\" typecheck",
		"lint": "vp lint .",
		"lint:fix": "vp lint --fix .",
		"fmt": "vp fmt .",
		"fmt:check": "vp fmt --check .",
		"check": "vp check && vp run --filter \"./apps/*\" typecheck"
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"typescript": "^5.7.2",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"wrangler": "^4.60.0"
	},
	"packageManager": "pnpm@10.33.0"
}
